# Database (Neon)
DATABASE_URL=                   # pooled connection (pgBouncer) — used at runtime
DIRECT_URL=                     # direct connection — used only by prisma migrate

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=            # e.g. https://your-app.vercel.app

# Optional
ANTHROPIC_API_KEY=              # enables real CV extraction; falls back to mock if absent
INSTAGRAM_CLIENT_ID=            # required for Instagram OAuth
INSTAGRAM_CLIENT_SECRET=
NEXT_PUBLIC_POSTHOG_KEY=        # analytics; no-ops if absent
